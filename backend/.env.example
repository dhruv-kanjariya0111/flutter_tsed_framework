# Copy to .env.dev / .env.staging / .env.prod
# NEVER commit real values

NODE_ENV=dev
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/appdb

# JWT (generate strong secrets: openssl rand -base64 64)
JWT_SECRET=replace_with_strong_secret_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Observability
SENTRY_DSN=

# Jira Integration (optional — set jira: true in PROJECT_CONFIG.md to enable)
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=
