{
  "name": "client-api",
  "version": "1.0.0",
  "description": "Ts.ED backend — generated by Flutter x Ts.ED Framework",
  "scripts": {
    "start": "ts-node src/index.ts",
    "start:dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "build:prod": "tsc --project tsconfig.prod.json",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:contract": "jest --testPathPattern=contract",
    "test:load": "k6 run test/load/load-test.js",
    "openapi:validate": "spectral lint shared/openapi.yaml --ruleset .spectral.yaml",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@tsed/common": "^7.62.0",
    "@tsed/core": "^7.62.0",
    "@tsed/di": "^7.62.0",
    "@tsed/platform-express": "^7.62.0",
    "@tsed/swagger": "^7.62.0",
    "@tsed/ajv": "^7.62.0",
    "@tsed/passport": "^7.62.0",
    "@prisma/client": "^5.14.0",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.3.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "sanitize-html": "^2.13.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/sanitize-html": "^2.11.0",
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^9.5.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "@types/jest": "^29.5.12",
    "@types/supertest": "^6.0.2",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "nodemon": "^3.1.4",
    "typescript": "^5.4.5",
    "prisma": "^5.14.0",
    "prettier": "^3.3.2"
  }
}
