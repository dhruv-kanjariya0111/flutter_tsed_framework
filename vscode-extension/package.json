{
  "name": "flutter-tsed-framework",
  "displayName": "Flutter × Ts.ED Framework",
  "description": "Automation framework for Flutter apps with Ts.ED backends",
  "version": "1.0.0",
  "publisher": "boscdev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/boscdev/flutter-tsed-framework.git"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "icon": "icon.png",
  "activationEvents": ["workspaceContains:CLAUDE.md"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "flutter-tsed.init",           "title": "Flutter TSed: Init project",       "icon": "$(rocket)" },
      { "command": "flutter-tsed.tdd",            "title": "Flutter TSed: TDD feature",        "icon": "$(beaker)" },
      { "command": "flutter-tsed.tdd-backend",    "title": "Flutter TSed: TDD backend",        "icon": "$(server)" },
      { "command": "flutter-tsed.verify",         "title": "Flutter TSed: Verify",             "icon": "$(check-all)" },
      { "command": "flutter-tsed.review",         "title": "Flutter TSed: Review",             "icon": "$(eye)" },
      { "command": "flutter-tsed.plan",           "title": "Flutter TSed: Plan",               "icon": "$(list-ordered)" },
      { "command": "flutter-tsed.refactor",       "title": "Flutter TSed: Refactor",           "icon": "$(tools)" },
      { "command": "flutter-tsed.release",        "title": "Flutter TSed: Release",            "icon": "$(tag)" },
      { "command": "flutter-tsed.analyze-bugs",   "title": "Flutter TSed: Analyze bugs",       "icon": "$(bug)" },
      { "command": "flutter-tsed.perf-check",     "title": "Flutter TSed: Perf check",         "icon": "$(dashboard)" },
      { "command": "flutter-tsed.a11y-check",     "title": "Flutter TSed: A11y check",         "icon": "$(accessibility)" },
      { "command": "flutter-tsed.sync-contract",  "title": "Flutter TSed: Sync contract",      "icon": "$(sync)" },
      { "command": "flutter-tsed.api-design",     "title": "Flutter TSed: API design",         "icon": "$(symbol-interface)" },
      { "command": "flutter-tsed.migrate",        "title": "Flutter TSed: Migrate",            "icon": "$(arrow-right)" },
      { "command": "flutter-tsed.store-check",    "title": "Flutter TSed: Store check",        "icon": "$(package)" },
      { "command": "flutter-tsed.explore",        "title": "Flutter TSed: Explore",            "icon": "$(search)" },
      { "command": "flutter-tsed.offline-check",  "title": "Flutter TSed: Offline check",      "icon": "$(wifi-off)" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "flutter-tsed",
          "title": "Flutter TSed",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "flutter-tsed": [
        {
          "id": "flutter-tsed.commands",
          "name": "Commands",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "flutter-tsed.init",
          "when": "view == flutter-tsed.commands",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
